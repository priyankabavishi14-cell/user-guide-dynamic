rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper Functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() >= 1 && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Validation for Project Entity
    function isValidProject(data) {
      return data.keys().hasAll(['title', 'slug', 'updatedAt', 'createdBy'])
        && data.title is string && data.title.size() >= 1
        && data.slug is string && data.slug.matches('^[a-z0-9-]+$')
        && data.updatedAt == request.time
        && data.createdBy == request.auth.uid;
    }

    // Validation for Page Entity
    function isValidPage(data) {
      return data.keys().hasAll(['projectId', 'title', 'sequence', 'parentId', 'description', 'content', 'updatedAt', 'createdBy'])
        && data.keys().size() >= 8
        && data.projectId is string && isValidId(data.projectId)
        && data.title is string && data.title.size() >= 1 && data.title.size() <= 200
        && data.sequence is int
        && (data.parentId == null || (data.parentId is string && isValidId(data.parentId)))
        && data.description is string && data.description.size() <= 500
        && data.content is string && data.content.size() <= 102400 // 100KB
        && data.updatedAt == request.time
        && data.createdBy == request.auth.uid;
    }

    match /projects/{projectId} {
      allow get, list: if true;
      allow create: if isSignedIn() && isValidId(projectId) && isValidProject(incoming());
      allow update: if isSignedIn() && isValidProject(incoming()) && incoming().createdBy == existing().createdBy;
      allow delete: if isSignedIn() && existing().createdBy == request.auth.uid;
    }

    match /pages/{pageId} {
      // Public Read Access
      allow get, list: if true;

      // Admin Write Access
      allow create: if isSignedIn() 
        && isValidId(pageId)
        && isValidPage(incoming());

      allow update: if isSignedIn()
        && isValidPage(incoming())
        && incoming().createdBy == existing().createdBy
        && (
          (incoming().diff(existing()).affectedKeys().hasOnly(['content', 'updatedAt', 'title', 'description', 'sequence', 'parentId', 'projectId']))
        );

      allow delete: if isSignedIn();
    }
  }
}
